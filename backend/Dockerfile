FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1
WORKDIR /srv

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential libgomp1 && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install -r requirements.txt

COPY . .

EXPOSE 8000
# On first boot, build artifacts then serve. Mount a volume on /srv/data to persist.
CMD ["sh", "-c", "python -c 'import os,sys; sys.path.insert(0,\"ml\"); import retrain; retrain.run()' || true; uvicorn app.main:app --host 0.0.0.0 --port 8000"]
